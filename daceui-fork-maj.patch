+name: tests-legacy
+
+# Best-effort CI for the legacy code base (Python 3.6 era).
+# DaceUI currently has no test suite of its own: this job performs an
+# import smoke check plus the (empty) historical suite, with the
+# known-good dependency pins from constraints-legacy.txt and
+# ecreall_dace / ecreall_pontus installed from their maintained forks.
+# To be stabilised during Phase 1 of the modernisation roadmap
+# (reproducible legacy build / "golden master") — see README.md.
+
+on:
+  push:
+  pull_request:
+  workflow_dispatch:
+
+jobs:
+  legacy-tests:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - name: Import smoke check and test suite in a Python 3.6 container
+        run: |
+          docker run --rm -v "$PWD":/src -w /src python:3.6-buster bash -ec "
+            pip install --no-cache-dir --upgrade 'pip<22' &&
+            pip install --no-cache-dir -c constraints-legacy.txt \
+              'git+https://github.com/michaellaunay/dace.git#egg=ecreall_dace' \
+              'git+https://github.com/michaellaunay/pontus.git#egg=ecreall_pontus' &&
+            pip install --no-cache-dir -c constraints-legacy.txt -e . &&
+            python -c 'import daceui' &&
+            python setup.py test
+          "
